{
  "expo": {
    "name": "E-Citoyen CI",
    "slug": "citizenci",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "fastshot",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "e-Citoyen CI a besoin de la reconnaissance vocale pour transcrire vos demandes.",
        "NSMicrophoneUsageDescription": "e-Citoyen CI a besoin d'acc\u00e9der au microphone pour la dict\u00e9e vocale."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#F5DEB3"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.moreldev.citizenci"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5DEB3"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "e-Citoyen CI a besoin d'acc\u00e9der au microphone pour la dict\u00e9e vocale.",
          "speechRecognitionPermission": "e-Citoyen CI a besoin de la reconnaissance vocale pour transcrire vos demandes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "morel-dev",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "318f2520-aa58-43d6-be48-bb9ccb07bf9e"
      }
    }
  }
}