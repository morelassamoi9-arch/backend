{
  "expo": {
    "name": "Citizenci",
    "slug": "citizenci",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "fastshot",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#F5DEB3"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5DEB3"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "e-Citoyen CI a besoin d'accéder au microphone pour la dictée vocale.",
          "speechRecognitionPermission": "e-Citoyen CI a besoin de la reconnaissance vocale pour transcrire vos demandes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/b70b47f6-fb50-4ecb-a8e0-db9f29e6d75f/dev-preview/"
    }
  }
}
